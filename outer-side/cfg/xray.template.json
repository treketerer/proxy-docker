{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "port": 9010,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "$XRAY_CLIENT_ID",
            "flow": "xtls-rprx-vision"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "dest": "www.microsoft.com:443",
          "xver": 0,
          "serverNames": [
            "www.microsoft.com"
          ],
          "privateKey": "$XRAY_PRIVATE_KEY",
          "shortIds": [
            "2ebd6e17dec6a5d9"
          ]
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls"]
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom"
    }
  ]
}